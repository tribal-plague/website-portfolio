# ── Sanity CMS ────────────────────────────────────────────────────────────────
# 1. Create a free project at https://sanity.io
# 2. Copy the Project ID from sanity.io/manage → your project → Settings → API
VITE_SANITY_PROJECT_ID=your_project_id_here

# 3. Dataset name (default is "production" — leave unless you changed it)
VITE_SANITY_DATASET=production

# 4. Create a write token: sanity.io/manage → API → Tokens → Add API token
#    Set role to "Editor" (can edit content, cannot change billing/settings)
#    Add this token to Vercel: Project → Settings → Environment Variables
VITE_SANITY_WRITE_TOKEN=your_write_token_here
